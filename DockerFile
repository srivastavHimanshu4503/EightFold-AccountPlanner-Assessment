# Use lightweight Python image
FROM python:3.11-slim

# Prevent Python from writing .pyc files and buffering stdout
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Set working directory
WORKDIR /app

# Install system dependencies (IMPORTANT for stability + fonts)
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    fonts-dejavu-core \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip (prevents install issues)
RUN pip install --upgrade pip

# Copy requirements first (better caching)
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy project files
COPY . .

# Ensure DejaVu font exists for PDF export
# (your code expects DejaVuSans.ttf in project root)
RUN cp /usr/share/fonts/truetype/dejavu/DejaVuSans.ttf ./DejaVuSans.ttf || true

# Hugging Face Spaces expects this port
EXPOSE 7860

# Start Chainlit server
CMD ["chainlit", "run", "app.py", "--host", "0.0.0.0", "--port", "7860"]